# ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA versione o .env no GitHub!
# ─────────────────────────────────────────────

# URL da API do Google Sheets (Stein ou Sheet.best)
# Exemplo Stein:    https://api.steinhq.com/v1/storages/SEU_STORAGE_ID
# Exemplo Sheet.best: https://api.sheetbest.com/sheets/SEU_UUID
VITE_SHEETS_API_URL=https://api.steinhq.com/v1/storages/COLE_SEU_ID_AQUI

# Credenciais de acesso ao app
VITE_APP_USER=admin
VITE_APP_PASSWORD=sua_senha_segura
